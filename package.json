// ── AI HELPERS ────────────────────────────────────────────────────────────────

const API_KEY = import.meta.env.VITE_ANTHROPIC_API_KEY || "";

async function callAI(systemPrompt, userPrompt) {
  if (!API_KEY) throw new Error("VITE_ANTHROPIC_API_KEY not set in .env.local");
  const r = await fetch("https://api.anthropic.com/v1/messages", {
    method: "POST",
    headers: {
      "Content-Type": "application/json",
      "x-api-key": API_KEY,
      "anthropic-version": "2023-06-01",
      "anthropic-dangerous-direct-browser-access": "true",
    },
    body: JSON.stringify({
      model: "claude-sonnet-4-20250514",
      max_tokens: 1000,
      system: systemPrompt,
      messages: [{ role: "user", content: userPrompt }],
    }),
  });
  if (!r.ok) throw new Error(`API error ${r.status}`);
  const d = await r.json();
  return d.content?.[0]?.text || "";
}

const AI_SYS = `You are a senior HSE and human factors specialist with deep expertise in EI 3580 (Energy Institute Guidance on Human Factors in Task-Based Risk Assessment, January 2025), ADNOC risk management standards (HSE-RM-ST01), and oil & gas operational safety. You assist in conducting task-based risk assessments integrating energy sources, error-producing conditions (EPCs), and hierarchy of controls. Respond with valid JSON only — no markdown fences, no preamble.`;

async function aiSuggestHazards(stepDesc, energies) {
  const text = await callAI(AI_SYS,
    `Task step: "${stepDesc}"\nSelected energy sources: ${energies.join(", ")}\n\nFor each selected energy source, suggest specific hazards relevant to this step in an oil & gas context. Return JSON:\n{"hazards":[{"hazard":"string","energy":"string","consequence":"string","severity_suggestion":1,"justification":"string"}]}`
  );
  try { return JSON.parse(text); } catch { return { hazards: [] }; }
}

async function aiSuggestEPCs(stepDesc, hazards) {
  const text = await callAI(AI_SYS,
    `Task step: "${stepDesc}"\nIdentified hazards: ${hazards.join("; ")}\n\nUsing the EI 3580 EPC framework, identify the most likely error-producing conditions. EPC IDs available: j1–j11 (Job Factors), p1–p6 (Person Factors), o1–o4 (Organisation Factors). Return JSON:\n{"epcs":[{"id":"string","label":"string","category":"Job/Person/Organisation","reason":"string","risk_impact":"string"}]}`
  );
  try { return JSON.parse(text); } catch { return { epcs: [] }; }
}

async function aiSuggestControls(stepDesc, hazards, epcLabels, iS, iL) {
  const cat = getCat(iS, iL);
  const text = await callAI(AI_SYS,
    `Task step: "${stepDesc}"\nHazards: ${hazards.join("; ")}\nEPCs: ${epcLabels.join("; ")}\nInitial risk: Severity ${iS}, Likelihood ${iL}${cat ? " → " + CAT[cat].label : ""}\n\nSuggest comprehensive risk controls using hierarchy of controls (Elimination → Substitution → Engineering → Administrative → PPE). Address BOTH hazards and EPCs. Return JSON:\n{"controls":[{"type":"eliminate|substitute|engineering|admin|ppe","measure":"string","addresses":"hazard|epc|both","effectiveness":"High|Medium|Low","rationale":"string"}]}`
  );
  try { return JSON.parse(text); } catch { return { controls: [] }; }
}

async function aiFullReview(ra) {
  const stepsText = ra.steps.map((s, i) => {
    const epcLabels = s.epcs.map(id => {
      for (const cat of Object.values(EPC)) {
        const item = cat.items.find(i => i.id === id);
        if (item) return item.label;
      }
      return id;
    });
    return `Step ${i + 1}: ${s.description} | Energies: ${s.energies.join(",")} | Hazards: ${s.hazards.join(",")} | EPCs: ${epcLabels.join(",")} | Controls: ${s.controls.map(c => c.measure).join(",")} | Initial: ${s.iS || "?"}${s.iL || "?"} | Residual: ${s.rS || "?"}${s.rL || "?"}`;
  }).join("\n");
  const text = await callAI(AI_SYS,
    `Risk Assessment Quality Review\nTask: ${ra.title}\nLocation: ${ra.location}\nDept: ${ra.dept}\nDate: ${ra.date}\n\n${stepsText}\n\nConduct a thorough quality review against EI 3580 six-stage methodology and ADNOC risk management standards. Return JSON:\n{"overall_quality":"Excellent|Good|Adequate|Needs Improvement","completeness_score":0,"summary":"string","strengths":["string"],"findings":[{"severity":"Critical|Major|Minor","step":0,"issue":"string","recommendation":"string"}],"human_factors_coverage":"Good|Partial|Poor","residual_risk_adequate":true}`
  );
  try { return JSON.parse(text); } catch { return null; }
}

